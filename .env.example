# MoltClip Environment Configuration

# === Cloudflare ===
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# === Master Worker (CF) ===
MASTER_WORKER_URL=https://moltclip-master.<account>.workers.dev
API_KEY=               # Bearer token for CLI/dashboard access to Master Worker

# === Worker URLs (for VPS → CF communication) ===
IDENTITY_WORKER_URL=https://moltclip-identity.<account>.workers.dev
PAYMENT_WORKER_URL=https://moltclip-payment.<account>.workers.dev

# === VPS Controller ===
CONTROLLER_PORT=8800
CONTROLLER_SECRET=     # shared secret for VPS ↔ Master Worker auth (generate: openssl rand -hex 32)
SKILLS_DIR=/app/packages/skills  # path to built MCP skill packages on VPS

# === Database (VPS) ===
DATABASE_URL=postgresql://moltclip:moltclip@localhost:5432/moltclip

# === Redis (VPS) ===
REDIS_URL=redis://localhost:6379

# === Agent Identity ===
AGENTMAIL_API_KEY=
AGENTMAIL_DOMAIN=agents.yourdomain.to
ENCRYPTION_KEY=        # AES-256-GCM key for credential vault (generate: openssl rand -base64 32)

# === Payments ===
PRIVACY_API_KEY=       # Privacy.com virtual cards
STRIPE_SECRET_KEY=     # Stripe direct charges
CROSSMINT_API_KEY=     # Crossmint payment API (optional)

# === AI Providers ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=           # xAI Grok API (api.x.ai/v1)

# === Skills & Harness ===
FIRECRAWL_API_KEY=     # Firecrawl content extraction
X_BEARER_TOKEN=        # X API v2 bearer token
GITHUB_TOKEN=          # Fine-grained PAT (repo read/write, PR write)
UPWORK_API_KEY=        # Upwork GraphQL API (optional)

# === Orchestrator ===
ORCHESTRATOR_POLL_INTERVAL_MS=5000
MAX_CONCURRENT_GOALS=3
MAX_SUBTASKS_PER_GOAL=10

# === Browser ===
MAX_BROWSERS=10
BROWSER_PROFILE_DIR=/data/profiles
BROWSER_BACKUP_INTERVAL_HOURS=6

# === Agent Instances ===
MAX_CLAUDE_INSTANCES=4
MAX_CODEX_INSTANCES=2

# === Tailscale / Tunnel ===
TAILSCALE_AUTH_KEY=
CF_TUNNEL_TOKEN=
