# MoltClip Environment Configuration

# === Cloudflare ===
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# === VPS Controller ===
CONTROLLER_PORT=8800
CONTROLLER_SECRET=  # shared secret with CF Master Worker

# === Database (VPS) ===
DATABASE_URL=postgresql://moltclip:moltclip@localhost:5432/moltclip

# === Redis (VPS) ===
REDIS_URL=redis://localhost:6379

# === Agent Identity ===
AGENTMAIL_API_KEY=
AGENTMAIL_DOMAIN=agents.yourdomain.to

# === Payments ===
PRIVACY_API_KEY=
STRIPE_SECRET_KEY=

# === AI Providers ===
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === Browser ===
MAX_BROWSERS=10
BROWSER_PROFILE_DIR=/data/profiles
BROWSER_BACKUP_INTERVAL_HOURS=6

# === Agent Instances ===
MAX_CLAUDE_INSTANCES=4
MAX_CODEX_INSTANCES=2

# === Tailscale / Tunnel ===
TAILSCALE_AUTH_KEY=
CF_TUNNEL_TOKEN=
