{
  "name": "moltclip",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy:workers": "pnpm --filter './packages/workers/*' deploy",
    "deploy:vps": "./scripts/deploy-vps.sh"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.0.0",
    "wrangler": "^3.99.0"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4"
}
